# GEMINI_API_KEY: Required for the Registrar Name Feasibility Advisor and advisory board audits.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ADMIN_PASSWORD: Password for the blog author panel. Defaults to 'admin123' if unset.
ADMIN_PASSWORD="admin123"

# NODE_ENV: Set to "production" on your hosting server. Leave unset for local development.
# NODE_ENV="production"

# APP_URL: The URL where this applet is hosted.
# Automatically configured in production, or set locally to http://localhost:3000.
APP_URL="http://localhost:3000"

# --- Hostinger MySQL Database Configuration ---
# Set these variables to connect the server to your Hostinger MySQL Database.
# If unset, the server will fall back to local JSON storage (submissions.json & blog-posts.json).
DB_HOST="localhost"
DB_USER="u453824837_Incroute_Leads"
DB_PASSWORD="YOUR_DATABASE_PASSWORD"
DB_NAME="u453824837_Client"

# --- Prisma Platform Database (for portal, admin, compliance) ---
DATABASE_URL="mysql://u453824837_Incroute_Admin:YOUR_PASSWORD@localhost:3306/u453824837_Platform"

# --- SMTP Email Notification Configuration ---
# Set these variables to enable automatic email alerts whenever a client fills out the contact form.
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_USER="notifications@incroute.com"
SMTP_PASS="YOUR_SMTP_EMAIL_PASSWORD"
NOTIFICATION_TO="admin@incroute.com"
NOTIFICATION_TO_SECONDARY="partner@incroute.com"



