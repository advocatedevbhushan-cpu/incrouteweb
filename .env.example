# GEMINI_API_KEY: Optional fallback AI API key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DEEPSEEK_API_KEY: Required for the Registrar Name Feasibility Advisor.
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# ADMIN_PASSWORD: Password for the blog author panel. Defaults to 'admin123' if unset.
ADMIN_PASSWORD="admin123"

# APP_URL: The URL where this applet is hosted.
# Automatically configured in production, or set locally to http://localhost:3000.
APP_URL="http://localhost:3000"

