generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── ROLES & PERMISSIONS ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  TEAM_MEMBER
  CLIENT
  CLIENT_SUB_USER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  role          Role      @default(CLIENT)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  sessions      Session[]
  permissions   UserPermission[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  assignments   TeamAssignment[]  @relation("assignedMember")
  entities      EntityAccess[]

  @@index([email])
  @@index([role])
}

model Permission {
  id          String           @id @default(cuid())
  resource    String           // e.g. "documents", "compliance", "invoices"
  action      String           // e.g. "read", "create", "update", "delete"
  description String?
  users       UserPermission[]

  @@unique([resource, action])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  grantedBy    String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

// ─── SESSIONS & TOKENS ───────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?  @db.Text
  device    String?
  browser   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastActive DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.VarChar(512)
  family    String   // Token family for rotation detection
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([family])
}

// ─── TEAM ASSIGNMENTS ────────────────────────────────────────────

model TeamAssignment {
  id         String   @id @default(cuid())
  memberId   String
  entityId   String
  assignedAt DateTime @default(now())
  assignedBy String?

  member User @relation("assignedMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, entityId])
}

model EntityAccess {
  id       String @id @default(cuid())
  userId   String
  entityId String
  role     String @default("owner") // owner, admin, viewer

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
}

// ─── AUDIT LOG ───────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // login, logout, password_change, role_change, etc.
  resource  String?  // What was affected
  details   String?  @db.Text
  ipAddress String?
  userAgent String?  @db.Text
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── PASSWORD RESET ──────────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ═══════════════════════════════════════════════════════════════════
// OPERATIONS MODELS — Admin Platform
// ═══════════════════════════════════════════════════════════════════

// ─── CLIENT ──────────────────────────────────────────────────────

model Client {
  id                String   @id @default(cuid())
  companyName       String
  contactName       String
  contactEmail      String
  contactPhone      String?
  industry          String?
  status            ClientStatus @default(ACTIVE)
  relationshipMgrId String?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  entities      Entity[]
  tasks         Task[]
  documents     Document[]
  invoices      Invoice[]
  tickets       Ticket[]
  consultations Consultation[]
  legalMatters  LegalMatter[]
  trademarks    TrademarkApp[]
  activities    Activity[]
  serviceRequests ServiceRequest[]

  @@index([status])
  @@index([contactEmail])
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ONBOARDING
  CHURNED
}

// ─── ENTITY ──────────────────────────────────────────────────────

model Entity {
  id              String       @id @default(cuid())
  clientId        String
  name            String
  type            EntityType
  cin             String?
  pan             String?
  gstin           String?
  incorporatedAt  DateTime?
  status          EntityStatus @default(ACTIVE)
  complianceScore Int          @default(100)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  client          Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  complianceTasks ComplianceTask[]
  documents       Document[]

  @@index([clientId])
  @@index([type])
}

enum EntityType {
  PVT_LTD
  LLP
  OPC
  PARTNERSHIP
  SECTION_8
  PUBLIC_LTD
  FOREIGN
}

enum EntityStatus {
  ACTIVE
  DORMANT
  STRIKE_OFF
  UNDER_LIQUIDATION
}

// ─── COMPLIANCE ──────────────────────────────────────────────────

model ComplianceTask {
  id          String           @id @default(cuid())
  entityId    String
  title       String
  category    ComplianceCategory
  dueDate     DateTime
  priority    Priority         @default(MEDIUM)
  status      ComplianceStatus @default(PENDING)
  assigneeId  String?
  completedAt DateTime?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([status])
  @@index([dueDate])
  @@index([assigneeId])
}

enum ComplianceCategory {
  ROC
  GST
  DIN_KYC
  INCOME_TAX
  TRADEMARK
  BOARD_MEETING
  ANNUAL_FILING
  TDS
  EPF
  OTHER
}

enum ComplianceStatus {
  PENDING
  IN_PROGRESS
  UNDER_REVIEW
  COMPLETED
  OVERDUE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── TASKS ───────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  clientId    String?
  title       String
  description String?    @db.Text
  assigneeId  String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([assigneeId])
  @@index([status])
  @@index([clientId])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  UNDER_REVIEW
  COMPLETED
  BLOCKED
}

// ─── DOCUMENTS ───────────────────────────────────────────────────

model Document {
  id         String         @id @default(cuid())
  clientId   String?
  entityId   String?
  title      String
  category   String
  fileName   String
  fileUrl    String
  fileSize   Int?
  version    Int            @default(1)
  status     DocStatus      @default(DRAFT)
  uploadedBy String?
  approvedBy String?
  approvedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  entity Entity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([category])
}

enum DocStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
  EXPIRED
}

// ─── INVOICES ────────────────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  invoiceNo   String        @unique
  amount      Decimal       @db.Decimal(12, 2)
  tax         Decimal?      @db.Decimal(12, 2)
  total       Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  description String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ─── TICKETS ─────────────────────────────────────────────────────

model Ticket {
  id          String       @id @default(cuid())
  clientId    String
  subject     String
  description String?      @db.Text
  priority    Priority     @default(MEDIUM)
  status      TicketStatus @default(OPEN)
  assigneeId  String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([assigneeId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  ESCALATED
  RESOLVED
  CLOSED
}

// ─── CONSULTATIONS ───────────────────────────────────────────────

model Consultation {
  id          String             @id @default(cuid())
  clientId    String
  topic       String
  advisorId   String?
  scheduledAt DateTime
  duration    Int                @default(30) // minutes
  status      ConsultationStatus @default(SCHEDULED)
  meetingLink String?
  notes       String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([scheduledAt])
  @@index([advisorId])
}

enum ConsultationStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── LEGAL MATTERS ───────────────────────────────────────────────

model LegalMatter {
  id          String           @id @default(cuid())
  clientId    String
  title       String
  type        String
  lawyerId    String?
  priority    Priority         @default(MEDIUM)
  status      LegalStatus      @default(OPEN)
  deadline    DateTime?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

enum LegalStatus {
  OPEN
  IN_PROGRESS
  HEARING_SCHEDULED
  UNDER_REVIEW
  COMPLETED
  CLOSED
}

// ─── TRADEMARK ───────────────────────────────────────────────────

model TrademarkApp {
  id              String          @id @default(cuid())
  clientId        String
  name            String
  applicationNo   String?
  classNumber     String
  status          TrademarkStatus @default(FILED)
  currentStage    String?
  nextAction      String?
  filedAt         DateTime?
  renewalDate     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

enum TrademarkStatus {
  FILED
  UNDER_EXAMINATION
  OBJECTION_RAISED
  HEARING_SCHEDULED
  PUBLISHED
  REGISTERED
  RENEWAL_DUE
  ABANDONED
}

// ─── ACTIVITY LOG ────────────────────────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  clientId  String?
  userId    String?
  type      String
  title     String
  details   String?  @db.Text
  createdAt DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 8 — ONBOARDING, SERVICE DELIVERY & COMMUNICATION
// ═══════════════════════════════════════════════════════════════════

// ─── SERVICE REQUESTS ────────────────────────────────────────────

model ServiceRequest {
  id              String              @id @default(cuid())
  clientId        String?
  userId          String?
  serviceType     ServiceType
  status          ServiceRequestStatus @default(DRAFT)
  progress        Int                 @default(0) // 0-100
  currentStep     String              @default("account") // onboarding step
  assignedMgrId   String?
  assignedExecId  String?
  companyName     String?
  companyInfo     Json?               // Company details JSON
  promoterInfo    Json?               // Directors/partners JSON
  expectedDate    DateTime?
  notes           String?             @db.Text
  submittedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  client          Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  documents       ServiceDocument[]
  steps           ServiceStep[]
  timeline        TimelineEntry[]

  @@index([clientId])
  @@index([status])
  @@index([userId])
}

enum ServiceType {
  PVT_LTD_INCORPORATION
  LLP_INCORPORATION
  OPC_INCORPORATION
  PARTNERSHIP_REGISTRATION
  SECTION_8_INCORPORATION
  GST_REGISTRATION
  TRADEMARK_FILING
  COMPLIANCE_ANNUAL
  TAX_RETURN
  LEGAL_DRAFTING
  VIRTUAL_OFFICE
  MSME_REGISTRATION
  FSSAI_REGISTRATION
}

enum ServiceRequestStatus {
  DRAFT
  PENDING_DOCUMENTS
  UNDER_REVIEW
  IN_PROGRESS
  FILED
  AWAITING_APPROVAL
  COMPLETED
  ON_HOLD
  CANCELLED
}

// ─── SERVICE STEPS (Task breakdown per service) ──────────────────

model ServiceStep {
  id              String          @id @default(cuid())
  serviceRequestId String
  title           String
  order           Int
  status          StepStatus      @default(PENDING)
  assigneeId      String?
  notes           String?         @db.Text
  completedAt     DateTime?
  createdAt       DateTime        @default(now())

  serviceRequest  ServiceRequest  @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([order])
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
  SKIPPED
}

// ─── SERVICE DOCUMENTS (collected during onboarding) ─────────────

model ServiceDocument {
  id              String            @id @default(cuid())
  serviceRequestId String
  documentType    DocumentType
  label           String
  fileName        String?
  fileUrl         String?
  fileSize        Int?
  status          DocVerifyStatus   @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectReason    String?
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  serviceRequest  ServiceRequest    @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
  @@index([status])
}

enum DocumentType {
  PAN_CARD
  AADHAAR
  PASSPORT
  ADDRESS_PROOF
  BANK_STATEMENT
  PHOTOGRAPH
  DSC
  UTILITY_BILL
  NOC
  RENT_AGREEMENT
  PARTNERSHIP_DEED
  MOA_AOA
  GST_CERTIFICATE
  TRADEMARK_LOGO
  OTHER
}

enum DocVerifyStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  NEEDS_CLARIFICATION
  EXPIRED
}

// ─── TIMELINE ────────────────────────────────────────────────────

model TimelineEntry {
  id              String          @id @default(cuid())
  serviceRequestId String?
  clientId        String?
  userId          String?
  type            String          // application_created, document_uploaded, etc.
  title           String
  description     String?
  metadata        Json?
  createdAt       DateTime        @default(now())

  serviceRequest  ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)

  @@index([serviceRequestId])
  @@index([clientId])
  @@index([createdAt])
}

// ─── WHATSAPP MESSAGES ───────────────────────────────────────────

model WhatsAppMessage {
  id            String          @id @default(cuid())
  recipientPhone String
  templateId    String
  variables     Json?
  status        MessageStatus   @default(QUEUED)
  provider      String          @default("whatsapp_business") // whatsapp_business, twilio, interakt, wati
  providerMsgId String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  failReason    String?
  retryCount    Int             @default(0)
  createdAt     DateTime        @default(now())

  @@index([recipientPhone])
  @@index([status])
  @@index([templateId])
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RETRY
}

// ─── MESSAGE TEMPLATES ───────────────────────────────────────────

model MessageTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  channel     String   // whatsapp, email, sms
  subject     String?  // for email
  body        String   @db.Text
  variables   Json?    // [{name, description, required}]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── RELATIONSHIP MANAGER ASSIGNMENT ─────────────────────────────

model RelationshipAssignment {
  id              String   @id @default(cuid())
  clientId        String
  managerId       String   // User ID of RM
  executiveId     String?  // Compliance executive
  supportId       String?  // Support contact
  assignedAt      DateTime @default(now())
  
  @@unique([clientId])
  @@index([managerId])
}
